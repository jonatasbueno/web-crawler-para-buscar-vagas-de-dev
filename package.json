{
  "name": "crawler-vagas-dev",
  "version": "1.0.0",
  "description": "Scraper de vagas focado em Desenvolvedores de Software Frontend / React Native.",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "npm run run:once:loose",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "run:cron:8": "npm run db:migrate && tsx src/index.ts --scheduled-hour 8",
    "run:cron:13": "npm run db:migrate && tsx src/index.ts --scheduled-hour 13",
    "run:cron:20": "npm run db:migrate && tsx src/index.ts --scheduled-hour 20",
    "run:cron:catch-up": "npm run db:migrate && tsx src/index.ts --catch-up",
    "run:once:loose": "npm run db:migrate && tsx src/index.ts --once-loose",
    "cron:install": "bash scripts/install-cron.sh"
  },
  "keywords": [
    "scraper",
    "vagas",
    "typescript",
    "puppeteer"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.0",
    "knex": "^3.1.0",
    "slack-notify": "^2.0.7",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
